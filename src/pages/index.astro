---
import Layout from "~/layouts/PageLayout.astro";

const metadata = {
  title: "Team Odyssey — Records",
};
---

<Layout metadata={metadata}>

  <section class="flex flex-col items-center justify-center min-h-[70vh] gap-6 px-6 text-center">

    <h1 class="text-4xl font-bold tracking-tight">
      Records Page
    </h1>

    <p class="text-lg text-muted dark:text-slate-400 max-w-md">
      View the progress of this website across multiple years.
    </p>

    <ul class="flex flex-col gap-2 mt-2">
      <li>
        <a href="http://2026.teamodyssey.space/team/" class="text-primary underline hover:opacity-80 transition-opacity">
          IRC 2025-2026
        </a>
      </li>
      <li>
        <a href="http://teamodyssey.space/team/" class="text-primary underline hover:opacity-80 transition-opacity">
          Current
        </a>
      </li>
    </ul>

  </section>

</Layout>