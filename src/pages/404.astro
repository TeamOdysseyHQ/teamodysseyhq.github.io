---
import Layout from "~/layouts/PageLayout.astro";

const metadata = {
  title: "404 — Page Not Found",
};
---

<Layout metadata={metadata}>

  <section class="flex flex-col items-center justify-center min-h-[70vh] gap-6 px-6 text-center">

    <h1 class="text-8xl font-bold text-primary">404</h1>

    <p class="text-2xl font-semibold">Page not found.</p>

    <p class="text-lg text-muted dark:text-slate-400 max-w-md">
      This page doesn't exist or was moved.
    </p>

    <a href="/" class="text-primary underline hover:opacity-80 transition-opacity">
      Back to home
    </a>

  </section>

</Layout>
